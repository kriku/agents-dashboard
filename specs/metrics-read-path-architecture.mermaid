---
title: "Metrics Read Path — Predefined Dashboard Architecture (Phase 1 v2.0)"
---
flowchart TB
    %% ───────────────────────────────────────────────
    %% TENANT-FACING DASHBOARD
    %% ───────────────────────────────────────────────
    subgraph TENANT_UI["Custom Dashboard · Tenant-Facing (Static Views)"]
        direction LR
        UI_AGENT["Agent\nOverview"]
        UI_TOOL["Tool Call\nPerformance"]
        UI_LLM["LLM Token\nUsage"]
        UI_ERR["Error\nBreakdown"]
        UI_COST["Cost\nTracking"]
    end

    %% ───────────────────────────────────────────────
    %% BACKEND-FOR-FRONTEND
    %% ───────────────────────────────────────────────
    subgraph BFF["Backend-for-Frontend (Go) · Stateless · HPA 3–15 replicas"]
        direction TB

        B_JWT["① JWT Validation\nextract user_id\norg_id · ws_id · role"]

        B_TENANT["② Derive Tenant ID\norg-{id}__ws-{id}\nfrom JWT claims\n(never from client)"]

        B_VIEW["③ View Lookup\ncompiled Go structs\n5 views · ~30 panels\npredefined PromQL"]

        B_EXEC["④ Parallel Execution\nexecute all panel\nqueries concurrently\n(bounded semaphore\nper workspace)"]

        B_AUDIT["⑤ Audit Log\nworkspace · user\nview_id · latency\nstatus"]

        B_JWT --> B_TENANT --> B_VIEW --> B_EXEC --> B_AUDIT
    end

    %% ───────────────────────────────────────────────
    %% INTERNAL GRAFANA
    %% ───────────────────────────────────────────────
    subgraph GRAFANA["Grafana · Internal Only (Platform Engineers)"]
        direction TB
        G_DS["Per-Tenant\nDatasources\n(secureJsonData:\nX-Scope-OrgID)"]
        G_FED["Fleet View\nDatasource\n(tenant federation)"]
        G_DASH["Grafonnet\nDashboards\n(GitOps via\nsidecar)"]
    end

    %% ───────────────────────────────────────────────
    %% MIMIR READ PATH
    %% ───────────────────────────────────────────────
    subgraph MIMIR_READ["Mimir Read Path (Shared by Both Consumers)"]
        direction TB
        QFE["Query Frontend\n• Query splitting (24h)\n• Result cache\n  (Memcached,\n   tenant-scoped keys)\n• 2+ replicas"]
        QSCHED["Query Scheduler\n• Per-tenant queues\n  (depth: 100)\n• Round-robin\n• HTTP 429 overflow"]
        QUERIER["Queriers\n• Shuffle-sharded\n  per workspace\n• PromQL evaluation"]
    end

    QFE --> QSCHED --> QUERIER

    %% ───────────────────────────────────────────────
    %% DATA SOURCES
    %% ───────────────────────────────────────────────
    ING["Ingesters\n(recent ~2h)"]
    SGW["Store Gateways\n(historical)"]

    %% ───────────────────────────────────────────────
    %% STORAGE & CACHE
    %% ───────────────────────────────────────────────
    OBJ[("Object Storage\nS3 / GCS\nper-tenant prefix")]
    MC["Memcached\nresult cache\nindex + chunk cache\n(tenant-scoped)"]

    %% ───────────────────────────────────────────────
    %% SUPPORTING SERVICES
    %% ───────────────────────────────────────────────
    IAM["IAM Service\nJWT issuance\nJWKS endpoint"]
    RC["Runtime Config\nhot-reload ≤10s\nper-workspace\nquery limits"]
    AUDIT_STORE[("Audit Log\ntamper-evident\nappend-only")]

    %% ───────────────────────────────────────────────
    %% FUTURE
    %% ───────────────────────────────────────────────
    CH_FUTURE["ClickHouse\n(Phase 2)\nSQL analytics"]

    %% ═══════════════════════════════════════════════
    %% CONNECTIONS — Tenant Dashboard Path
    %% ═══════════════════════════════════════════════
    TENANT_UI -- "HTTPS + JWT\nGET /api/views/{id}\n(no PromQL\nin request)" --> BFF

    B_EXEC -- "X-Scope-OrgID:\norg-{id}__ws-{id}\nPromQL from compiled\nview definitions" --> QFE

    %% ═══════════════════════════════════════════════
    %% CONNECTIONS — Grafana Path
    %% ═══════════════════════════════════════════════
    GRAFANA -- "X-Scope-OrgID\n(from secureJsonData)\nuser-written PromQL" --> QFE

    %% ═══════════════════════════════════════════════
    %% CONNECTIONS — Mimir Internal
    %% ═══════════════════════════════════════════════
    QUERIER -- "recent" --> ING
    QUERIER -- "historical" --> SGW
    SGW --> OBJ

    %% ═══════════════════════════════════════════════
    %% CONNECTIONS — Cache
    %% ═══════════════════════════════════════════════
    QFE -. "result cache" .-> MC
    SGW -. "index + chunk" .-> MC

    %% ═══════════════════════════════════════════════
    %% CONNECTIONS — Supporting
    %% ═══════════════════════════════════════════════
    B_JWT -. "JWKS" .-> IAM
    B_AUDIT --> AUDIT_STORE
    RC -. "query limits" .-> QSCHED

    %% ═══════════════════════════════════════════════
    %% CONNECTIONS — Future
    %% ═══════════════════════════════════════════════
    BFF -. "future:\nSQL panels" .-> CH_FUTURE

    %% ═══════════════════════════════════════════════
    %% ANNOTATIONS
    %% ═══════════════════════════════════════════════
    subgraph ELIMINATED["Eliminated in v2.0"]
        direction LR
        X1["❌ PostgreSQL"]
        X2["❌ Redis"]
        X3["❌ PromQL Parser"]
        X4["❌ Query Builder"]
        X5["❌ Dashboard CRUD"]
    end

    %% ═══════════════════════════════════════════════
    %% STYLES
    %% ═══════════════════════════════════════════════
    classDef tenant fill:#e8f5e9,stroke:#2e7d32,stroke-width:2px,color:#1b5e20
    classDef bff fill:#e3f2fd,stroke:#1565c0,stroke-width:2px,color:#0d47a1
    classDef grafana fill:#fff3e0,stroke:#e65100,stroke-width:2px,color:#bf360c
    classDef mimir fill:#f3e5f5,stroke:#6a1b9a,stroke-width:2px,color:#4a148c
    classDef data fill:#e8eaf6,stroke:#283593,stroke-width:2px,color:#1a237e
    classDef storage fill:#fce4ec,stroke:#c62828,stroke-width:2px,color:#b71c1c
    classDef cache fill:#f5f5f5,stroke:#616161,stroke-width:1px,color:#424242
    classDef support fill:#e0f7fa,stroke:#00695c,stroke-width:2px,color:#004d40
    classDef audit fill:#fff9c4,stroke:#f57f17,stroke-width:1px,color:#e65100
    classDef future fill:#f5f5f5,stroke:#9e9e9e,stroke-width:1px,stroke-dasharray:5 5,color:#757575
    classDef eliminated fill:#ffebee,stroke:#c62828,stroke-width:1px,stroke-dasharray:3 3,color:#b71c1c

    class UI_AGENT,UI_TOOL,UI_LLM,UI_ERR,UI_COST tenant
    class B_JWT,B_TENANT,B_VIEW,B_EXEC,B_AUDIT bff
    class G_DS,G_FED,G_DASH grafana
    class QFE,QSCHED,QUERIER mimir
    class ING,SGW data
    class OBJ storage
    class MC cache
    class IAM,RC support
    class AUDIT_STORE audit
    class CH_FUTURE future
    class X1,X2,X3,X4,X5 eliminated
