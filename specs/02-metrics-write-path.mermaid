---
title: "Metrics Write Path — AI Agent Monitoring Platform"
---
flowchart TB
    %% ───────────────────────────────────────────────
    %% AI AGENT FLEET
    %% ───────────────────────────────────────────────
    subgraph FLEET["AI Agent Fleet"]
        direction LR
        AG1["Agent\n(Workspace A)\nv2.3"]
        AG2["Agent\n(Workspace B)\nv2.4"]
        AG3["Agent\n(Workspace C)\nv2.3"]
    end

    %% ───────────────────────────────────────────────
    %% OTEL COLLECTOR — DAEMONSET
    %% ───────────────────────────────────────────────
    subgraph OTEL["OTel Collector · DaemonSet (1 per node)"]
        direction TB
        OT_RX["OTLP Receiver\ngRPC :4317 · HTTP :4318\nmetrics signal"]
        OT_K8S["K8s Metadata\nProcessor\npod · namespace\nnode · labels"]
        OT_RES["Resource\nProcessor\ninject agent_version\nworkspace_id hint"]
        OT_FILTER["Filter Processor\ndrop internal/debug\nmetrics · enforce\nallowlisted names"]
        OT_AGG["Cumulative →\nDelta Conversion\n(where needed)\nnormalize temporality"]
        OT_BATCH["Batch Processor\ntimeout: 5s\nmax_size: 8192"]
        OT_RETRY["Retry &\nPersistent Queue\nlocal WAL on disk\nsurvives pod restart"]

        OT_RX --> OT_K8S --> OT_RES --> OT_FILTER --> OT_AGG --> OT_BATCH --> OT_RETRY
    end

    %% ───────────────────────────────────────────────
    %% API GATEWAY
    %% ───────────────────────────────────────────────
    subgraph GW["API Gateway"]
        direction TB
        GW_TLS["TLS 1.3\nTermination"]
        GW_AUTH["API Key\nAuthentication\nlookup → workspace_id"]
        GW_RL["Global Rate\nLimiter\n(coarse, per IP)"]
        GW_HDR["Inject Headers\nX-Scope-OrgID =\norg-{id}__ws-{id}"]

        GW_TLS --> GW_AUTH --> GW_RL --> GW_HDR
    end

    %% ───────────────────────────────────────────────
    %% MIMIR DISTRIBUTOR
    %% ───────────────────────────────────────────────
    subgraph DIST["Mimir Distributor · Stateless (N replicas)"]
        direction TB
        D_RATE["Per-Workspace\nRate Limiter\nsamples/sec · bytes/sec\nHTTP 429 + Retry-After"]
        D_VALID["Sample Validation\n• label name/value format\n• max labels per series\n• max label length\n• timestamp bounds"]
        D_CARD["Cardinality\nEnforcement\n• max_global_series_per_user\n• max_global_series_per_metric\n• max_label_names_per_series"]
        D_SCRUB["Label Value\nScrubbing\n• PII in label values\n• secret patterns\n• custom workspace rules"]
        D_HA["HA Deduplication\naccept 1 of N\nreplica samples\nvia HA tracker"]
        D_RING["Hash-Ring\nRouting\nhash(tenant+labels)\n→ target ingesters\n(replication factor: 3)"]

        D_RATE --> D_VALID --> D_CARD --> D_SCRUB --> D_HA --> D_RING
    end

    %% ───────────────────────────────────────────────
    %% KAFKA INGEST STORAGE (Mimir 3.0)
    %% ───────────────────────────────────────────────
    KAFKA_INGEST(["Kafka · Ingest Storage\ntopic: mimir-ingest\npartitioned by\nhash(tenant+labels)\nreplication: 3"])

    %% ───────────────────────────────────────────────
    %% MIMIR INGESTER
    %% ───────────────────────────────────────────────
    subgraph ING["Mimir Ingester · Stateful (hash-ring)"]
        direction TB
        I_CONSUME["Kafka Consumer\nconsume from assigned\npartitions · exactly-once"]
        I_HEAD["In-Memory\nHead Block\n• per-tenant TSDB\n• active series tracking\n• ~2h of samples"]
        I_WAL["Write-Ahead Log\non local SSD\ncrash recovery\nbefore Kafka ack"]
        I_CUT["Block Cut\nevery ~2 hours\nfreeze head → block\nupload to object storage"]

        I_CONSUME --> I_HEAD
        I_HEAD --> I_WAL
        I_HEAD -- "every ~2h" --> I_CUT
    end

    %% ───────────────────────────────────────────────
    %% OBJECT STORAGE
    %% ───────────────────────────────────────────────
    subgraph STORE["Object Storage · S3 / GCS / Azure Blob"]
        direction TB
        BLK["Immutable TSDB Blocks\nper-tenant prefix:\n/tenant-{ws_id}/\n2h blocks → compacted"]
        IDX["Block Index\nlabel → series mapping\npostings lists"]
        CHK["Chunk Data\ncompressed samples\nXOR / gorilla encoding\n~7× compression"]
    end

    BLK --- IDX & CHK

    %% ───────────────────────────────────────────────
    %% COMPACTOR
    %% ───────────────────────────────────────────────
    subgraph COMPACT["Mimir Compactor · Split-and-Merge"]
        direction TB
        C_MERGE["Block Compaction\n2h → 12h → 24h\nreduce block count\nimprove query perf"]
        C_DEDUP["Block Dedup\nremove HA replicas\nat storage level"]
        C_RET["Retention\nEnforcement\nper-workspace TTL\ndelete expired blocks"]
        C_SPLIT["Split-and-Merge\nsharding for blocks\n> 64 GB index ceiling\nhorizontal compaction"]
    end

    C_MERGE --> C_DEDUP --> C_RET --> C_SPLIT

    %% ───────────────────────────────────────────────
    %% SIDE OUTPUTS
    %% ───────────────────────────────────────────────
    KAFKA_METER(["Kafka Topic:\nmetering-events\nsamples_count\nseries_count\nbytes per workspace"])
    KAFKA_ANOMALY(["Kafka Topic:\nmetrics-anomaly-input\nseparate consumer group"])
    OVERRIDES["Overrides\nExporter\nexposes all tenant limits\nas Prometheus metrics\nfor alerting"]

    %% ───────────────────────────────────────────────
    %% CONTROL PLANE
    %% ───────────────────────────────────────────────
    RUNTIME["Runtime Config\nhot-reload ≤10s\nper-workspace limits\ntier defaults\nplatform defaults"]
    SCHEMA_REG["Schema Registry\nmetric name allowlist\nlabel cardinality rules\nversion mapping"]
    CONFIG_STORE["Config Store\nper-workspace\nscrub patterns\ncustom label rules"]

    %% ═══════════════════════════════════════════════
    %% CONNECTIONS — Main write path
    %% ═══════════════════════════════════════════════
    FLEET -- "OTLP/gRPC\nGenAI metrics:\nllm.token.usage\nagent.invocation.duration\ntool.call.count\netc." --> OTEL
    OTEL -- "Prometheus\nRemote Write\nor OTLP/HTTP\nbatched" --> GW
    GW -- "forward with\nX-Scope-OrgID" --> DIST
    DIST -- "produce\nvalidated samples" --> KAFKA_INGEST
    KAFKA_INGEST -- "consume\nassigned partitions" --> ING
    I_CUT -- "upload\n2h block" --> STORE

    %% Compactor reads/writes storage
    COMPACT -- "read old\nblocks" --> STORE
    COMPACT -- "write compacted\nblocks · delete old" --> STORE

    %% ═══════════════════════════════════════════════
    %% CONNECTIONS — Side outputs
    %% ═══════════════════════════════════════════════
    D_RATE -- "emit metering\nevent on accept" --> KAFKA_METER
    KAFKA_INGEST -- "fan-out\n(separate consumer\ngroup)" --> KAFKA_ANOMALY
    D_CARD -- "expose usage" --> OVERRIDES

    %% ═══════════════════════════════════════════════
    %% CONNECTIONS — Control plane reads
    %% ═══════════════════════════════════════════════
    RUNTIME -. "ingestion rate\nburst · series caps\nretention period" .-> D_RATE
    RUNTIME -. "cardinality\nlimits" .-> D_CARD
    RUNTIME -. "retention\nTTL per tenant" .-> C_RET
    SCHEMA_REG -. "allowed metric\nnames · label rules" .-> D_VALID
    CONFIG_STORE -. "custom scrub\npatterns" .-> D_SCRUB

    %% ═══════════════════════════════════════════════
    %% STYLES
    %% ═══════════════════════════════════════════════
    classDef source fill:#e8f5e9,stroke:#2e7d32,stroke-width:2px,color:#1b5e20
    classDef otel fill:#e3f2fd,stroke:#1565c0,stroke-width:2px,color:#0d47a1
    classDef gateway fill:#bbdefb,stroke:#1565c0,stroke-width:2px,color:#0d47a1
    classDef kafka fill:#fff3e0,stroke:#e65100,stroke-width:2px,color:#bf360c
    classDef dist fill:#f3e5f5,stroke:#6a1b9a,stroke-width:2px,color:#4a148c
    classDef ingester fill:#e8eaf6,stroke:#283593,stroke-width:2px,color:#1a237e
    classDef storage fill:#fce4ec,stroke:#c62828,stroke-width:2px,color:#b71c1c
    classDef compactor fill:#e0f7fa,stroke:#00695c,stroke-width:2px,color:#004d40
    classDef control fill:#f5f5f5,stroke:#616161,stroke-width:1px,color:#424242
    classDef side fill:#fff9c4,stroke:#f57f17,stroke-width:1px,color:#e65100

    class AG1,AG2,AG3 source
    class OT_RX,OT_K8S,OT_RES,OT_FILTER,OT_AGG,OT_BATCH,OT_RETRY otel
    class GW_TLS,GW_AUTH,GW_RL,GW_HDR gateway
    class KAFKA_INGEST kafka
    class D_RATE,D_VALID,D_CARD,D_SCRUB,D_HA,D_RING dist
    class I_CONSUME,I_HEAD,I_WAL,I_CUT ingester
    class BLK,IDX,CHK storage
    class C_MERGE,C_DEDUP,C_RET,C_SPLIT compactor
    class RUNTIME,SCHEMA_REG,CONFIG_STORE control
    class KAFKA_METER,KAFKA_ANOMALY,OVERRIDES side
